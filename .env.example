# TMDB API Key for fetching movie/TV show metadata
# Get your free key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=
TMDB_READ_ACCESS_TOKEN=

# RetroAchievements API credentials (for game metadata)
# Get your key at: https://retroachievements.org/settings -> Keys
RA_API_USER=
RA_API_KEY=

# Identity wallet private key (32-byte hex, auto-generated if not set)
SIGNALING_WALLET=

# TURN server for WebRTC NAT traversal
# Get credentials at: https://www.metered.ca
METERED_DOMAIN=
METERED_SECRET_KEY=

# Wyzie Subs API key for subtitle search (movies + TV)
# Claim your free key at: https://sub.wyzie.io/redeem
WYZIE_API_KEY=
