{
	"$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
	"productName": "Mhaol",
	"version": "0.1.0",
	"identifier": "com.arktosmos.mhaol",
	"build": {
		"beforeDevCommand": "pnpm --filter frontend dev",
		"devUrl": "http://localhost:1530",
		"beforeBuildCommand": "pnpm --filter frontend build",
		"frontendDist": "./loading"
	},
	"app": {
		"windows": [
			{
				"title": "Mhaol",
				"width": 1280,
				"height": 800,
				"resizable": true,
				"fullscreen": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"resources": {
			"../../frontend/dist": "server/"
		}
	}
}
