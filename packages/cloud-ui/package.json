{
	"name": "cloud-ui",
	"version": "0.0.1",
	"type": "module",
	"private": true,
	"description": "Shared display types + Svelte components used by the cloud WebUI and the player app. Pure presentational — no SvelteKit, no $app/* imports, no API calls.",
	"svelte": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"svelte": "./src/index.ts",
			"types": "./src/index.ts"
		},
		"./types": {
			"types": "./src/types/index.ts",
			"default": "./src/types/index.ts"
		},
		"./components/*": {
			"svelte": "./src/components/*",
			"default": "./src/components/*"
		}
	},
	"files": [
		"src"
	],
	"scripts": {
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"lint": "echo 'no lint configured'",
		"test": "echo 'no tests'",
		"clean": "rm -rf .svelte-kit",
		"format": "echo 'no format'"
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"dependencies": {
		"classnames": "^2.5.1"
	},
	"devDependencies": {
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"typescript": "^5.0.0"
	}
}
