{
	"name": "addons",
	"version": "1.0.0",
	"description": "Addon modules for Mhaol",
	"type": "module",
	"addons": {
		"tmdb": {
			"source": "addon",
			"settings": [
				{
					"key": "tmdb.apiKey",
					"default": "",
					"envKey": "TMDB_API_KEY"
				}
			]
		},
		"torrent-search-thepiratebay": {
			"source": "addon"
		},
		"torrent-search-spanish": {
			"source": "addon"
		},
		"musicbrainz": {
			"source": "addon"
		},
		"retroachievements": {
			"source": "addon"
		},
		"youtube": {
			"source": "addon"
		},
		"lrclib": {
			"source": "addon"
		},
		"openlibrary": {
			"source": "addon"
		},
		"wyzie-subs": {
			"source": "addon"
		}
	},
	"exports": {
		"./tmdb": "./tmdb/src/index.ts",
		"./tmdb/types": "./tmdb/src/types.ts",
		"./tmdb/transform": "./tmdb/src/transform.ts",
		"./tmdb/cache-repository": "./tmdb/src/cache-repository.ts",
		"./torrent-search-thepiratebay": "./torrent-search-thepiratebay/src/index.ts",
		"./torrent-search-thepiratebay/types": "./torrent-search-thepiratebay/src/types.ts",
		"./torrent-search-thepiratebay/format": "./torrent-search-thepiratebay/src/format.ts",
		"./torrent-search-thepiratebay/parse-torrent-name": "./torrent-search-thepiratebay/src/parse-torrent-name.ts",
		"./torrent-search-spanish": "./torrent-search-spanish/src/index.ts",
		"./torrent-search-spanish/types": "./torrent-search-spanish/src/types.ts",
		"./torrent-search-spanish/is-castilian": "./torrent-search-spanish/src/is-castilian.ts",
		"./musicbrainz": "./musicbrainz/src/index.ts",
		"./musicbrainz/types": "./musicbrainz/src/types.ts",
		"./musicbrainz/transform": "./musicbrainz/src/transform.ts",
		"./musicbrainz/client": "./musicbrainz/src/client.ts",
		"./retroachievements": "./retroachievements/src/index.ts",
		"./retroachievements/types": "./retroachievements/src/types.ts",
		"./retroachievements/transform": "./retroachievements/src/transform.ts",
		"./youtube": "./youtube/src/index.ts",
		"./youtube/types": "./youtube/src/types.ts",
		"./youtube/helpers": "./youtube/src/helpers.ts",
		"./lrclib": "./lrclib/src/index.ts",
		"./lrclib/types": "./lrclib/src/types.ts",
		"./openlibrary": "./openlibrary/src/index.ts",
		"./openlibrary/types": "./openlibrary/src/types.ts",
		"./openlibrary/transform": "./openlibrary/src/transform.ts",
		"./wyzie-subs": "./wyzie-subs/src/index.ts",
		"./wyzie-subs/types": "./wyzie-subs/src/types.ts",
		"./common/rate-limiter": "./common/src/rate-limiter.ts",
		"./common/utils": "./common/src/utils.ts",
		"./common/addon-cache": "./common/src/addon-cache.ts"
	},
	"scripts": {
		"lint": "prettier --check . && eslint .",
		"check": "tsc --noEmit",
		"format": "prettier --write .",
		"test": "vitest run"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.3",
		"@types/better-sqlite3": "^7.6.12",
		"@types/node": "^22.15.3",
		"better-sqlite3": "^11.7.0",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.4.0",
		"prettier": "^3.4.2",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.56.1",
		"vitest": "^4.0.6"
	}
}
