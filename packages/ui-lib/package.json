{
	"name": "ui-lib",
	"version": "0.0.1",
	"type": "module",
	"exports": {
		"./components/*": "./src/components/*",
		"./css/*": "./src/css/*",
		"./services/*": "./src/services/*",
		"./adapters/*": "./src/adapters/*",
		"./types/*": "./src/types/*",
		"./utils/*": "./src/utils/*",
		"./lib/*": "./src/lib/*",
		"./data/*": "./src/data/*"
	},
	"dependencies": {
		"addons": "workspace:*",
		"blo": "^2.0.0",
		"classnames": "^2.5.1",
		"fflate": "^0.8.2",
		"html5-qrcode": "^2.3.8",
		"qrcode": "^1.5.4",
		"svelte-i18n": "^4.0.1",
		"viem": "^2.46.3",
		"webrtc": "workspace:*"
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"scripts": {
		"lint": "prettier --check . && eslint .",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"format": "prettier --write .",
		"clean": "rm -rf .svelte-kit",
		"test": "vitest run",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest run --coverage"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.3",
		"@sveltejs/vite-plugin-svelte": "^6.0.0",
		"@tailwindcss/vite": "^4.0.0",
		"@tauri-apps/api": "^2.10.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.2.8",
		"@types/qrcode": "^1.5.6",
		"@vitest/coverage-v8": "^4.0.6",
		"@vitest/ui": "^4.0.6",
		"daisyui": "^5.0.50",
		"dompurify": "^3.3.3",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.0",
		"globals": "^17.4.0",
		"happy-dom": "^20.0.10",
		"hls.js": "^1.6.15",
		"marked": "^17.0.5",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.56.1",
		"vite": "^7.0.4",
		"vitest": "^4.0.6"
	}
