{
	"name": "mhaol-monorepo",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "pnpm --filter server dev",
		"start": "pnpm --filter server start",
		"dev:backend": "set -a; . ./.env.app 2>/dev/null; set +a; PORT=1530 cargo run -p mhaol-backend --bin mhaol-server",
		"dev:frontend": "pnpm --filter mhaol-video dev",
		"build": "pnpm --filter server build",
		"build:backend": "cargo build --release --bin mhaol-server",
		"preview": "pnpm --filter mhaol-video preview",
		"test": "pnpm -r run test && cargo test -p mhaol-backend",
		"test:e2e": "pnpm --filter mhaol-video test:e2e",
		"lint": "pnpm -r run lint",
		"format": "pnpm -r run format",
		"check": "pnpm -r run check && cargo check -p mhaol-backend",
		"clean": "pnpm -r run clean && cargo clean",
		"signaling:dev": "pnpm --filter signaling dev",
		"signaling:deploy": "pnpm --filter signaling deploy",
		"tauri:dev": "pnpm --filter tube tauri:dev",
		"tauri:dev:tube": "pnpm --filter tube tauri:dev",
		"tauri:dev:cloud": "pnpm --filter cloud tauri:dev",
		"tauri:build": "pnpm --filter tube tauri:build",
		"tauri:build:tube": "pnpm --filter tube tauri:build",
		"tauri:build:cloud": "pnpm --filter cloud tauri:build",
		"app:server": "pnpm --filter server dev",
		"app:video": "pnpm --filter video dev",
		"app:tube": "pnpm --filter tube dev",
		"app:website": "pnpm --filter website dev",
		"app:cloud": "pnpm --filter cloud tauri:dev",
		"app:cloud:web": "pnpm --filter cloud dev",
		"app:cloud:headless": "pnpm --filter cloud headless",
		"app:torrent": "pnpm --filter torrent tauri:dev",
		"app:torrent:web": "pnpm --filter torrent dev",
		"app:torrent:headless": "pnpm --filter torrent headless",
		"app:signaling": "pnpm --filter signaling-app tauri:dev",
		"app:signaling:web": "pnpm --filter signaling-app dev",
		"app:signaling:headless": "pnpm --filter signaling-app headless",
		"install:deps": "sudo apt-get update && sudo apt-get install -y build-essential pkg-config libssl-dev libonig-dev libgstreamer1.0-dev libgstreamer-plugins-base1.0-dev libgstreamer-plugins-bad1.0-dev gstreamer1.0-plugins-base gstreamer1.0-plugins-good gstreamer1.0-plugins-bad gstreamer1.0-plugins-ugly gstreamer1.0-libav"
	},
	"engines": {
		"node": ">=18",
		"pnpm": ">=9"
	},
	"pnpm": {
		"onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
	}
}
