{
	"name": "mhaol-monorepo",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "pnpm p2p-server:build && pnpm ytdl-rust:build && pnpm signaling:build && pnpm -r --filter frontend dev",
		"build": "pnpm -r --filter frontend build",
		"preview": "pnpm -r --filter frontend preview",
		"test": "pnpm -r run test",
		"test:e2e": "pnpm -r --filter frontend test:e2e",
		"lint": "pnpm -r run lint",
		"format": "pnpm -r run format",
		"check": "pnpm -r run check",
		"clean": "pnpm -r run clean",
		"signaling:build": "pnpm --filter signaling build",
		"signaling:start": "pnpm --filter signaling start",
		"signaling:dev": "pnpm --filter signaling dev",
		"torrent:build": "cargo build --manifest-path packages/rust-torrent/Cargo.toml",
		"torrent:test": "cargo test --manifest-path packages/rust-torrent/Cargo.toml",
		"torrent:check": "cargo check --manifest-path packages/rust-torrent/Cargo.toml",
		"yt:test": "pnpm -r --filter yt-download test",
		"db:test": "pnpm -r --filter database test",
		"p2p-stream:build": "cargo build --manifest-path packages/p2p-stream/Cargo.toml",
		"p2p-stream:test": "cargo test --manifest-path packages/p2p-stream/Cargo.toml",
		"p2p-stream:check": "cargo check --manifest-path packages/p2p-stream/Cargo.toml",
		"p2p-server:build": "cargo build --manifest-path packages/p2p-stream-server/Cargo.toml",
		"ytdl-rust:build": "cargo build --manifest-path packages/rust-yt-dlp/Cargo.toml",
		"ytdl-rust:test": "cargo test --manifest-path packages/rust-yt-dlp/Cargo.toml",
		"ytdl-rust:check": "cargo check --manifest-path packages/rust-yt-dlp/Cargo.toml",
		"tauri:dev": "pnpm -r --filter tauri dev",
		"tauri:build": "pnpm -r --filter tauri build"
	},
	"engines": {
		"node": ">=18",
		"pnpm": ">=9"
	},
	"pnpm": {
		"onlyBuiltDependencies": ["better-sqlite3", "node-datachannel"]
	}
}
