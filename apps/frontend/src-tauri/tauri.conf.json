{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mhaol Client",
  "version": "0.1.0",
  "identifier": "com.arktosmos.mhaol-client",
  "build": {
    "frontendDist": "../dist-static",
    "devUrl": "http://localhost:1570",
    "beforeDevCommand": "pnpm --filter frontend dev",
    "beforeBuildCommand": "pnpm --filter frontend build"
  },
  "app": {
    "windows": [
      {
        "title": "Mhaol Client",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "minSdkVersion": 24
    }
  }
}
