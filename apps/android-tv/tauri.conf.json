{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mhaol Android TV",
  "version": "0.1.0",
  "identifier": "com.arktosmos.mhaol.androidtv",
  "build": {
    "frontendDist": "../../packages/frontend/dist-static",
    "devUrl": "http://localhost:9898",
    "beforeBuildCommand": "pnpm --filter frontend build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Mhaol Android TV",
        "url": "index.html",
        "fullscreen": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
