{
	"name": "video-cloud",
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 1540 --strictPort",
		"dev:full": "node scripts/dev.js",
		"start": "node scripts/start.js",
		"build": "vite build",
		"build:full": "cargo build --release --bin mhaol-server && vite build",
		"preview": "vite preview --port 1540 --strictPort",
		"dev:backend": "PORT=1540 cargo run -p mhaol-backend --bin mhaol-server",
		"build:backend": "cargo build --release --bin mhaol-server",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test": "vitest run",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:ui": "playwright test --ui",
		"headless": "node scripts/headless.js",
		"clean": "rm -rf dist-static .svelte-kit"
	},
	"dependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"classnames": "^2.5.1",
		"fflate": "^0.8.2",
		"html5-qrcode": "^2.3.8",
		"qrcode": "^1.5.4",
		"addons": "workspace:*",
		"frontend": "workspace:*",
		"ui-lib": "workspace:*",
		"viem": "^2.46.3"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.3",
		"@playwright/test": "^1.58.2",
		"@sveltejs/kit": "^2.22.0",
		"@sveltejs/vite-plugin-svelte": "^6.0.0",
		"@tailwindcss/vite": "^4.0.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.2.8",
		"@types/qrcode": "^1.5.6",
		"@vitest/coverage-v8": "^4.0.6",
		"@vitest/ui": "^4.0.6",
		"daisyui": "^5.0.50",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.0",
		"globals": "^17.4.0",
		"happy-dom": "^20.0.10",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.56.1",
		"vite": "^7.0.4",
		"vitest": "^4.0.6"
	}
}
