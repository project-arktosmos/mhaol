{
	"$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
	"productName": "Mhaol Torrent",
	"version": "0.1.0",
	"identifier": "com.arktosmos.mhaol-torrent",
	"build": {
		"beforeDevCommand": "pnpm --filter torrent dev:tauri",
		"devUrl": "http://localhost:1528",
		"beforeBuildCommand": "pnpm --filter torrent build",
		"frontendDist": "../dist-static"
	},
	"app": {
		"windows": [
			{
				"title": "Mhaol Torrent",
				"width": 1280,
				"height": 800,
				"resizable": true,
				"fullscreen": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
