{
	"name": "server",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "node scripts/dev.js",
		"start": "node scripts/start.js",
		"build": "cargo build --release --bin mhaol-server && pnpm --filter mhaol-video build",
		"dev:frontend": "pnpm --filter mhaol-video dev",
		"dev:backend": "PORT=1530 cargo run -p mhaol-backend --bin mhaol-server",
		"build:frontend": "pnpm --filter mhaol-video build",
		"build:backend": "cargo build --release --bin mhaol-server"
	},
	"dependencies": {
		"mhaol-video": "workspace:*"
	}
}
