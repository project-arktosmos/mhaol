{
	"name": "mhaol-website",
	"version": "0.0.1",
	"type": "module",
	"private": true,
	"description": "Public informational site for the Mhaol project. Static SvelteKit SPA built with Tailwind 4 + DaisyUI 5, sharing the cloud-ui component + icon set.",
	"scripts": {
		"dev": "vite dev --port 9897 --strictPort",
		"build": "vite build",
		"preview": "vite preview --port 9897 --strictPort",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test": "echo 'no tests'",
		"clean": "rm -rf dist-static .svelte-kit"
	},
	"dependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"classnames": "^2.5.1",
		"cloud-ui": "workspace:*"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.3",
		"@sveltejs/kit": "^2.22.0",
		"@sveltejs/vite-plugin-svelte": "^6.0.0",
		"@tailwindcss/vite": "^4.0.0",
		"daisyui": "^5.0.50",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.0",
		"globals": "^17.4.0",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.56.1",
		"vite": "^7.0.4"
	}
}
