{
	"$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
	"productName": "Mhaol Hub",
	"version": "0.1.0",
	"identifier": "com.arktosmos.mhaol-hub",
	"build": {
		"beforeDevCommand": "pnpm --filter hub dev",
		"devUrl": "http://localhost:1400",
		"beforeBuildCommand": "pnpm --filter hub build",
		"frontendDist": "../dist-static"
	},
	"app": {
		"windows": [
			{
				"title": "Mhaol Hub",
				"width": 900,
				"height": 700,
				"resizable": true,
				"fullscreen": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
