{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mhaol Player",
  "identifier": "com.arktosmos.mhaol.player",
  "build": {
    "frontendDist": "../../player/dist-static",
    "devUrl": "http://localhost:9595",
    "beforeDevCommand": "pnpm --filter player dev",
    "beforeBuildCommand": "pnpm --filter player build"
  },
  "app": {
    "windows": [
      {
        "title": "Mhaol Player",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ]
  }
}
