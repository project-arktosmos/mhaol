{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mhaol Cloud",
  "version": "0.1.0",
  "identifier": "com.arktosmos.mhaol.cloud",
  "build": {
    "frontendDist": "../web/dist-static",
    "devUrl": "http://localhost:9898",
    "beforeBuildCommand": "BASE_PATH=/player pnpm --filter player build && pnpm --filter cloud build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
