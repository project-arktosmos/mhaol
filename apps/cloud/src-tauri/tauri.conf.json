{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mhaol Cloud",
  "version": "0.1.0",
  "identifier": "com.arktosmos.mhaol.cloud",
  "build": {
    "frontendDist": "../../tauri/web/dist-static",
    "devUrl": "http://localhost:1571",
    "beforeDevCommand": "(lsof -i:1571 >/dev/null 2>&1) || pnpm --filter tauri-web dev",
    "beforeBuildCommand": "pnpm --filter tauri-web build"
  },
  "app": {
    "windows": [
      {
        "title": "Mhaol Cloud",
        "width": 900,
        "height": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
