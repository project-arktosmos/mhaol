{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mhaol Cloud",
  "version": "0.1.0",
  "identifier": "com.arktosmos.mhaol.cloud",
  "build": {
    "frontendDist": "../web/dist-static",
    "devUrl": "http://localhost:9898",
    "beforeDevCommand": "(lsof -i:9898 >/dev/null 2>&1) || pnpm --filter cloud dev",
    "beforeBuildCommand": "pnpm --filter cloud build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Mhaol Cloud",
        "url": "http://localhost:9898",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
